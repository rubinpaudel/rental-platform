{
  "name": "@rental-platform/config",
  "version": "0.0.0",
  "private": true,
  "description": "Zod-validated environment config for the rental platform",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@rental-platform/tsconfig": "workspace:*",
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
