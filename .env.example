# ──────────────────────────────────────────────────────────────
# Rental platform local development env vars.
# Copy to .env.local and fill in real values.
# .env.local is gitignored — never commit it.
#
# Validated by @rental-platform/config at boot (Zod). Boot fails
# fast if anything required is missing or malformed.
# ──────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000

# ── Database (Postgres) ───────────────────────────────────────
# Local: docker-compose Postgres. Prod: Railway Postgres add-on
# injects DATABASE_URL automatically.
# Host port is 5433 (5432 is left free for other local Postgres instances).
DATABASE_URL=postgres://rental:rental@localhost:5433/rental

# ── Object storage (S3-compatible) ────────────────────────────
# Local S3 emulation is MinIO (see infra/docker-compose.yml).
# MinIO requires path-style addressing and an explicit endpoint.
# In prod, point these at real AWS S3 (leave S3_ENDPOINT blank for
# AWS, or set it for an S3-compatible provider).
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=rental-platform-local
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
