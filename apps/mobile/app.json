{
  "expo": {
    "name": "Plekje",
    "slug": "plekje-mobile",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "plekje",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "eu.plekje.mobile",
      "supportsTablet": false
    },
    "android": {
      "package": "eu.plekje.mobile",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
