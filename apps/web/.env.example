# Public base URL of the identity API (NestJS, v1) where Better Auth is
# mounted at /api/auth/*. The Better Auth React client appends /api/auth.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public base URL of the photo bucket. The v3 listing API stores only
# storageKeys; the frontend appends them onto this base to render listing
# photos. Local MinIO defaults to <endpoint>/<bucket>; prod fronts the
# bucket with a CDN such as https://cdn.plekje.be.
NEXT_PUBLIC_S3_PUBLIC_BASE=http://localhost:9000/rental-platform-local
