meta {
  name: signup tenant
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/sign-up/email
  body: json
  auth: none
}

body:json {
  {
    "name": "Tenant Tess",
    "email": "{{tenantEmail}}",
    "password": "{{password}}",
    "role": "tenant",
    "orgKind": "private"
  }
}

assert {
  res.status: eq 200
}

tests {
  test("returns the created user", function () {
    expect(res.getBody().user.email).to.equal(bru.getVar("tenantEmail"));
  });
}
